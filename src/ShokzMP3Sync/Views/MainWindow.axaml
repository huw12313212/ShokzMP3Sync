<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShokzMP3Sync.ViewModels"
        x:Class="ShokzMP3Sync.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ShokzMP3Sync"
        Width="700" Height="600"
        MinWidth="500" MinHeight="400">

    <Window.Styles>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="Border.channelCard">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Styles>

    <Panel>
        <!-- Main Content -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="4" Margin="24">

                <!-- Device Status -->
                <Border Classes="card">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Ellipse Grid.Column="0" Width="12" Height="12"
                                 Margin="0,0,10,0" VerticalAlignment="Center">
                            <Ellipse.Styles>
                                <Style Selector="Ellipse">
                                    <Setter Property="Fill" Value="#CCCCCC"/>
                                </Style>
                            </Ellipse.Styles>
                        </Ellipse>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding DeviceStatusText}" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="{Binding DeviceSpaceText}" Foreground="Gray" FontSize="12"
                                       IsVisible="{Binding IsDeviceConnected}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding ToolStatusText}"
                                   VerticalAlignment="Center" FontSize="12" Foreground="Gray"/>
                    </Grid>
                </Border>

                <!-- Channels Section -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,8">
                    <TextBlock Classes="sectionTitle" Text="YouTube 頻道" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="+ 新增頻道" Command="{Binding OpenAddDialogCommand}"
                            Classes="accent" Padding="16,6"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Channels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChannelViewModel">
                            <Border Classes="channelCard">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="{Binding CurrentCount, StringFormat='{}{0} 首'}"
                                                       Foreground="Gray" VerticalAlignment="Center" FontSize="12"/>
                                            <TextBlock Text="{Binding KeepCount, StringFormat='/ 保留 {0}'}"
                                                       Foreground="Gray" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Url}" Foreground="Gray" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <Button Content="同步"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SyncChannelCommand}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding !IsSyncing}"
                                                Padding="12,4"/>
                                        <Button Content="編輯"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenEditDialogCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="12,4"/>
                                        <Button Content="刪除"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveChannelCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="12,4" Foreground="Red"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding StatusText}"
                                               IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="Gray" FontSize="11" Margin="0,4,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state for channels -->
                <TextBlock Text="尚未新增任何頻道，點擊「+ 新增頻道」開始設定"
                           IsVisible="{Binding !Channels.Count}"
                           Foreground="Gray" HorizontalAlignment="Center" Margin="0,20"/>

                <!-- Playlists Section -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,8">
                    <TextBlock Classes="sectionTitle" Text="YouTube 播放清單" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="+ 新增播放清單" Command="{Binding OpenAddPlaylistDialogCommand}"
                            Classes="accent" Padding="16,6"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Playlists}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PlaylistViewModel">
                            <Border Classes="channelCard">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="{Binding CurrentCount, StringFormat='{}{0} 首'}"
                                                       Foreground="Gray" VerticalAlignment="Center" FontSize="12"/>
                                            <TextBlock Text="/ 完整同步" Foreground="#5B9BD5"
                                                       VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Url}" Foreground="Gray" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <Button Content="同步"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SyncPlaylistCommand}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding !IsSyncing}"
                                                Padding="12,4"/>
                                        <Button Content="編輯"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenEditPlaylistDialogCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="12,4"/>
                                        <Button Content="刪除"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemovePlaylistCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="12,4" Foreground="Red"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding StatusText}"
                                               IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="Gray" FontSize="11" Margin="0,4,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="尚未新增任何播放清單"
                           IsVisible="{Binding !Playlists.Count}"
                           Foreground="Gray" HorizontalAlignment="Center" Margin="0,20"/>

                <!-- Sync All -->
                <Border Classes="card" Margin="0,8,0,0">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Button Content="全部同步" Command="{Binding SyncAllCommand}"
                                    IsEnabled="{Binding !IsSyncing}"
                                    Classes="accent" Padding="20,8" FontSize="14"/>
                            <Button Grid.Column="1" Content="取消" Command="{Binding CancelSyncCommand}"
                                    IsVisible="{Binding IsSyncing}" Padding="16,8" Margin="8,0,0,0"/>
                        </Grid>
                        <ProgressBar Value="{Binding SyncProgress}" Maximum="1"
                                     IsVisible="{Binding IsSyncing}" Height="4"/>
                        <TextBlock Text="{Binding SyncStatusText}"
                                   IsVisible="{Binding SyncStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Add/Edit Channel Dialog Overlay -->
        <Border IsVisible="{Binding IsAddDialogOpen}"
                Background="#80000000">
            <Border Background="White" CornerRadius="12" Padding="24"
                    MaxWidth="480" MaxHeight="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BoxShadow="0 4 24 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="頻道設定" FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="YouTube 頻道 URL" FontSize="12" Foreground="Gray"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding NewChannelUrl}" Watermark="https://www.youtube.com/@ChannelName"/>
                        <Button Grid.Column="1" Content="解析" Command="{Binding ResolveChannelNameCommand}"
                                IsEnabled="{Binding !IsResolvingChannel}"
                                Margin="8,0,0,0" Padding="12,6"/>
                    </Grid>

                    <TextBlock Text="頻道名稱" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding NewChannelName}" Watermark="頻道顯示名稱"/>

                    <TextBlock Text="裝置資料夾名稱" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding NewChannelFolder}" Watermark="同頻道名稱"/>

                    <TextBlock Text="保留最新影片數量" FontSize="12" Foreground="Gray"/>
                    <NumericUpDown Value="{Binding NewChannelKeepCount}" Minimum="1" Maximum="50"
                                   Increment="1" FormatString="0"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="取消" Command="{Binding CancelAddChannelCommand}" Padding="16,8"/>
                        <Button Content="確認" Command="{Binding ConfirmAddChannelCommand}"
                                Classes="accent" Padding="16,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
        <!-- Missing Dependencies Overlay -->
        <Border IsVisible="{Binding HasMissingDependencies}"
                Background="#E0FFFFFF" ZIndex="100">
            <Border Background="White" CornerRadius="12" Padding="32"
                    MaxWidth="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BoxShadow="0 4 24 #40000000">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <TextBlock Text="⚠ 缺少必要工具" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#D32F2F"/>
                    <TextBlock Text="{Binding MissingDependenciesText}"
                               FontSize="14" TextWrapping="Wrap" LineHeight="24"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <Border Background="#F5F5F5" CornerRadius="6" Padding="16" Margin="0,4,0,0">
                        <SelectableTextBlock Text="brew install yt-dlp ffmpeg"
                                             FontFamily="Menlo,monospace" FontSize="14"
                                             HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Border>

        <!-- Add/Edit Playlist Dialog Overlay -->
        <Border IsVisible="{Binding IsAddPlaylistDialogOpen}"
                Background="#80000000">
            <Border Background="White" CornerRadius="12" Padding="24"
                    MaxWidth="480" MaxHeight="360"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BoxShadow="0 4 24 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="播放清單設定" FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="YouTube 播放清單 URL" FontSize="12" Foreground="Gray"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding NewPlaylistUrl}" Watermark="https://www.youtube.com/...list=PL..."/>
                        <Button Grid.Column="1" Content="解析" Command="{Binding ResolvePlaylistNameCommand}"
                                IsEnabled="{Binding !IsResolvingPlaylist}"
                                Margin="8,0,0,0" Padding="12,6"/>
                    </Grid>

                    <TextBlock Text="播放清單名稱" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding NewPlaylistName}" Watermark="播放清單顯示名稱"/>

                    <TextBlock Text="裝置資料夾名稱" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding NewPlaylistFolder}" Watermark="同播放清單名稱"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="取消" Command="{Binding CancelAddPlaylistCommand}" Padding="16,8"/>
                        <Button Content="確認" Command="{Binding ConfirmAddPlaylistCommand}"
                                Classes="accent" Padding="16,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</Window>
